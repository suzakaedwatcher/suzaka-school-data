---
import Layout from '../layouts/Layout.astro'
import Cite from '../components/Cite.astro'
import RefList from '../components/RefList.astro'

const refs = [
  { n: 1, label: '答申書 資料10-1 p.21 問4-1', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '市民の優先課題で「小中一貫」は構成比1.9%。最下位から2番目' },
  { n: 2, label: '答申書 資料10-5 p.86 問2-3', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '児童の72.7%が「今のままでよい」' },
  { n: 3, label: '基本方針（案）Q&A（2025年4月）', url: 'https://www.city.suzaka.nagano.jp/material/files/group/25/kihonhoushinanQA.pdf', detail: '全28問中10問が「今後検討」' },
  { n: 4, label: '須坂市 公共施設等総合管理計画（2024年12月改訂）', url: 'https://www.city.suzaka.nagano.jp/material/files/group/2/koukyousisetsu_sougou.pdf', detail: '公共施設の延床面積のうち学校が約43%' },
  { n: 5, label: '須坂市 学校施設長寿命化計画（2020年3月）', url: 'https://www.city.suzaka.nagano.jp/material/files/group/25/gakkoshisetsu_chojumyouka202003.pdf', detail: '校舎の目標使用年数80年' },
  { n: 6, label: '文科省 手引き改訂 議論のまとめ（案）概要（第9回 2026年3月11日）', url: 'https://www.mext.go.jp/content/20260310-mtx_syoto02-000047969-3.pdf', detail: '「結論ありきで評価することを避けなければならない」' },
  { n: 7, label: '総務省「類似団体別市町村財政指数表」令和5年度', detail: '須坂市の教育施設投資は類似団体平均の29%' },
  { n: 8, label: '須坂市 2026年度予算案', url: 'https://www.city.suzaka.nagano.jp/', detail: '財政調整基金2026年度末 約2億円。ふるさと納税除外▲23.3億円/年' },
  { n: 9, label: '文科省建設単価基準（2025年度 RC造35.41万円/㎡）・須坂小改修実績による試算', detail: 'パターンにより市負担6億〜88億円。起債による分割負担は未考慮' },
  { n: 10, label: '3月議会答弁', url: 'https://www.city.suzaka.nagano.jp/shigikai/koho_kocho/99.html', detail: '教育長「反対の方がほとんどの話し合いには行けない」' },
  { n: 11, label: '須坂市議会 山県市行政視察報告', url: 'https://www.city.suzaka.nagano.jp/shigikai/gikaikatsudo/1/5644.html', detail: '統廃合を撤回し12校一体運営の「山県方式」を視察' },
  { n: 12, label: '須坂市総合教育会議 議事録（2024年9月30日）', url: 'https://www.city.suzaka.nagano.jp/material/files/group/2/20240930sougoukyouiku251212.pdf', detail: '学園構想が初めて正式に協議された場。当初非公開。総務部長「財政的理由でとん挫する可能性もある」' },
  { n: 13, label: '第2次須坂市教育大綱（2021〜2025年度）', url: 'https://www.city.suzaka.nagano.jp/material/files/group/25/82056942.pdf', detail: '「学園構想」の文言なし。2026年3月で期限切れ' },
  { n: 14, label: '地方教育行政の組織及び運営に関する法律', url: 'https://elaws.e-gov.go.jp/document?lawid=331AC0000000162', detail: '第21条（教育委員会の権限）、第22条（首長の権限）、第1条の3〜4（総合教育会議・教育大綱）' },
  { n: 15, label: '地域説明会 会議録（2025年7〜8月 全8回）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '全12ブロック・8回開催の質疑応答を収録' },
]
---

<Layout title="何が問題なのか — 須坂学園構想ウォッチ" description="須坂学園構想の真の問題は「統合すべきか」ではなく「比較検討なしに結論が出ている」こと">
  <a href="/" class="text-sm text-muted hover:underline">&larr; ホームに戻る</a>

  <article class="mt-6">
    <h1 class="text-3xl font-black text-primary mb-3">何が問題なのか</h1>
    <p class="text-base leading-relaxed text-muted mb-10">
      問題は「統合すべきか否か」ではありません。<br />
      <strong class="text-gray-900">費用も選択肢も示さないまま、方針だけ決めようとしている</strong>ことが問題です。
    </p>

    <!-- 問題は本物 -->
    <section class="bg-card rounded-lg p-6 shadow-sm mb-10">
      <h2 class="font-bold text-lg text-primary mb-4">須坂の学校が課題を抱えていることは事実です</h2>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
        <div class="text-center">
          <div class="text-2xl font-black text-primary">2031年</div>
          <div class="text-xs text-muted mt-1">東中が全学年単級に<br />教員配置が困難</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-black text-primary">47人</div>
          <div class="text-xs text-muted mt-1">豊丘小の児童数<br />複式学級が発生中</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-black text-primary">築35年〜</div>
          <div class="text-xs text-muted mt-1">11小学校すべて<br />老朽化が進行</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-black text-accent">29%</div>
          <div class="text-xs text-muted mt-1">教育施設投資<br />類似市の3割以下<Cite n={7} /></div>
        </div>
      </div>

      <p class="text-sm leading-relaxed">この状況を見れば、<strong>何らかの対応が必要だという点では、おそらく誰も異論がない</strong>のではないでしょうか。</p>
    </section>

    <!-- 進め方への疑問 -->
    <section class="mb-10">
      <h2 class="font-bold text-xl text-primary mb-6 border-b-2 border-primary pb-2">現在の進め方への疑問</h2>

      <div class="space-y-6">
        <!-- 1 -->
        <div class="bg-card rounded-lg p-6 shadow-sm border-l-4 border-primary">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-2xl font-black text-primary/30">1</span>
            <h3 class="font-bold">結論に至るプロセスが見えない</h3>
          </div>

          <div class="flex flex-wrap gap-4 mb-4">
            <div class="bg-gray-50 rounded-lg px-4 py-3 text-center">
              <div class="text-xl font-black text-primary">1.9%</div>
              <div class="text-xs text-muted">小中一貫を優先課題に<br />挙げた市民の割合<Cite n={1} /></div>
            </div>
            <div class="bg-gray-50 rounded-lg px-4 py-3 text-center">
              <div class="text-xl font-black text-primary">73%</div>
              <div class="text-xs text-muted">「今のままでよい」<br />と答えた児童<Cite n={2} /></div>
            </div>
          </div>

          <p class="text-sm leading-relaxed text-muted mb-3">
            にもかかわらず「15校→4学園の義務教育学校化」という方向性が示されており、この方向性がどのように導き出されたのかが見えにくい状況です。
          </p>
          <p class="text-sm leading-relaxed text-muted">
            2020〜2021年度の2つの検討会議の提言には「小中一貫」の文言が一切ありません。「須坂モデル」の中身は2021年2月の<strong>NIER講演会の内容と酷似</strong>しており、文科省「手引き」第4章（小規模校存続の選択肢）は検討された形跡がありません。
            <a href="/detail/nier-analysis" class="text-primary underline">詳しい分析 →</a>
          </p>
        </div>

        <!-- 2 -->
        <div class="bg-card rounded-lg p-6 shadow-sm border-l-4 border-primary">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-2xl font-black text-primary/30">2</span>
            <h3 class="font-bold">費用の全体像が見えない</h3>
          </div>

          <div class="flex flex-wrap gap-4 mb-4">
            <div class="bg-gray-50 rounded-lg px-4 py-3 text-center">
              <div class="text-xl font-black text-primary">6億〜88億</div>
              <div class="text-xs text-muted">パターンによる<br />市負担の振れ幅<Cite n={9} /></div>
            </div>
            <div class="bg-gray-50 rounded-lg px-4 py-3 text-center">
              <div class="text-xl font-black text-accent">約2億</div>
              <div class="text-xs text-muted">財政調整基金の<br />残高見込み<Cite n={8} /></div>
            </div>
          </div>

          <p class="text-sm leading-relaxed text-muted mb-3">
            建設・改修にいくらかかるのか、現時点で公表されていません。<Cite n={3} />
            金額を示さずに方針を決めることはできないはずです。
          </p>
          <p class="text-sm leading-relaxed text-muted">
            現計画の30年総負担73.5億円には<strong>使い続ける5校舎の改修費68.5億円が含まれていません。</strong>これを含めると実質92〜119億円になります。
            <a href="/detail/cost-comparison" class="text-primary underline">5つの選択肢の比較 →</a>
          </p>
        </div>

        <!-- 3 -->
        <div class="bg-card rounded-lg p-6 shadow-sm border-l-4 border-primary">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-2xl font-black text-primary/30">3</span>
            <h3 class="font-bold">他の選択肢が検討されていない</h3>
          </div>
          <p class="text-sm leading-relaxed text-muted mb-3">
            統合以外にも方法はあります。
          </p>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="bg-gray-100 text-xs font-bold px-3 py-1 rounded-full">小規模特認校（全国700校超）</span>
            <span class="bg-gray-100 text-xs font-bold px-3 py-1 rounded-full">合同授業・山県方式</span>
            <span class="bg-gray-100 text-xs font-bold px-3 py-1 rounded-full">ICT遠隔授業</span>
          </div>
          <p class="text-sm leading-relaxed text-muted">
            須坂市議会自身が山県市を視察し<Cite n={11} />、統廃合を撤回して12校一体運営する方法を調査しています。しかしこれらは基本方針案で検討されていません。
          </p>
        </div>

        <!-- 4 -->
        <div class="bg-card rounded-lg p-6 shadow-sm border-l-4 border-primary">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-2xl font-black text-primary/30">4</span>
            <h3 class="font-bold">「教育改革」と「施設削減」の関係</h3>
          </div>

          <div class="flex flex-wrap gap-4 mb-4">
            <div class="bg-gray-50 rounded-lg px-4 py-3 text-center">
              <div class="text-xl font-black text-primary">43%</div>
              <div class="text-xs text-muted">公共施設に占める<br />学校の割合<Cite n={4} /></div>
            </div>
          </div>

          <p class="text-sm leading-relaxed text-muted">
            公共施設の延床面積を減らすには、学校を削るのが最も効果的です。一方で2020年策定の長寿命化計画は「校舎を80年使う」方針。<Cite n={5} />
            「80年使う計画」と「統合して役割を終える計画」が同時に存在しており、この関係が整理されていません。
          </p>
        </div>

        <!-- 5 -->
        <div class="bg-card rounded-lg p-6 shadow-sm border-l-4 border-primary">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-2xl font-black text-primary/30">5</span>
            <h3 class="font-bold">対話のプロセスが止まっている</h3>
          </div>
          <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
            「反対の方がほとんどの話し合いには行けない」
            <span class="block text-xs text-muted not-italic mt-1">— 教育長、2026年3月議会答弁<Cite n={10} /></span>
          </blockquote>
          <p class="text-sm leading-relaxed text-muted mt-3">
            異なる意見を持つ市民との対話の場が設けられていない状況です。
          </p>
        </div>
      </div>
    </section>

    <!-- 意思決定の構造 -->
    <section class="bg-card rounded-lg p-6 shadow-sm mb-10">
      <h2 class="font-bold text-lg text-primary mb-4">誰が決めているのか</h2>

      <div class="bg-gray-50 border rounded-lg p-4 mb-6 text-sm">
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="bg-primary text-white text-xs font-bold px-2 py-0.5 rounded shrink-0">市長</span>
            <span class="text-muted">予算編成権、教育大綱の策定、教育長の任命、総合教育会議の招集<Cite n={14} /></span>
          </div>
          <div class="flex items-start gap-3 pl-6 border-l-2 border-primary/20">
            <span class="bg-gray-600 text-white text-xs font-bold px-2 py-0.5 rounded shrink-0">教育委員会</span>
            <span class="text-muted">学校の設置・廃止の決定権。ただし予算編成権なし</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="bg-gray-400 text-white text-xs font-bold px-2 py-0.5 rounded shrink-0">議会</span>
            <span class="text-muted">条例改正と予算の議決</span>
          </div>
        </div>
      </div>

      <p class="text-sm leading-relaxed text-muted mb-4">
        2024年9月30日の<strong>総合教育会議</strong>で、学園構想が初めて正式に協議されました。<Cite n={12} />
      </p>

      <div class="grid sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-gray-50 rounded-lg p-4">
          <div class="font-bold text-sm mb-3">議論されていること</div>
          <ul class="text-xs text-muted space-y-2">
            <li>子どもが減る（2040年に36%減）</li>
            <li>東中が喫緊（複式学級）</li>
            <li>財源の問題がある</li>
            <li>既存校舎の活用も考えるべき</li>
            <li>市民への説明が必要</li>
          </ul>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <div class="font-bold text-sm mb-3">まだ議論されていないこと</div>
          <ul class="text-xs text-muted space-y-2">
            <li>統合以外の選択肢（特認校・山県方式・ICTなど）</li>
            <li>費用の具体的な数字</li>
            <li>子どもの声（73%が「今のまま」のデータ）</li>
            <li>長寿命化計画との整合性の説明</li>
            <li>他市の事例（松本・佐久・山県など）</li>
          </ul>
        </div>
      </div>

      <div class="space-y-3 mb-4">
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「あと15年でそれをやるというのは驚き」「<strong>財政的理由でとん挫する可能性もある</strong>」
          <span class="block text-xs text-muted not-italic mt-1">— 総務部長<Cite n={12} /></span>
        </blockquote>
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「<strong>財源の問題は切り離せない</strong>」
          <span class="block text-xs text-muted not-italic mt-1">— 市長<Cite n={12} /></span>
        </blockquote>
      </div>

      <p class="text-sm leading-relaxed text-muted">
        「<strong>どう統合するか</strong>」は議論されていますが、「<strong>統合以外の方法も含めてどれが最善か</strong>」という比較の議論がまだ行われていません。
        費用の試算が公表されれば、市民も含めた建設的な議論が可能になるはずです。
      </p>
    </section>

    <!-- 費用はどこで議論されるのか -->
    <section class="bg-card rounded-lg p-6 shadow-sm mb-10 border-l-4 border-primary">
      <h2 class="font-bold text-lg text-primary mb-4">費用はどこで議論されるのか</h2>
      <p class="text-sm leading-relaxed text-muted mb-6">
        学園構想の費用は現時点で公表されていません。制度上、どこで議論されるべきなのでしょうか。
      </p>

      <div class="space-y-3 mb-6">
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「予算については、約30年かけて段階的に進める長期計画であり、現時点で総額は示せません」
          <span class="block text-xs text-muted not-italic mt-1">— 教育委員会（地域説明会）<Cite n={15} /></span>
        </blockquote>
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「財政的理由でとん挫する可能性もある」
          <span class="block text-xs text-muted not-italic mt-1">— 総務部長（総合教育会議）<Cite n={12} /></span>
        </blockquote>
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「財源の問題は切り離せない」
          <span class="block text-xs text-muted not-italic mt-1">— 市長（総合教育会議）<Cite n={12} /></span>
        </blockquote>
      </div>

      <div class="bg-yellow-50 rounded-lg p-5 text-sm">
        <p class="font-bold mb-3">制度上の整理:</p>
        <ul class="list-disc list-inside space-y-2">
          <li>教育委員会は「何をやるか」を決める権限はあるが、予算データを持っていない</li>
          <li>市長部局（総務部・財政課）は費用を試算できるが、出していない</li>
          <li>総合教育会議がその調整の場だが、費用付きの議論は行われていない</li>
        </ul>
        <p class="mt-4 leading-relaxed"><strong>費用を試算するのは市長部局（財政課）の役割であり、総合教育会議でそれを突き合わせるのが法の想定している手順です。</strong>
        この手順が進めば、市民にも費用を含めた判断材料が共有されるはずです。</p>
      </div>
    </section>

    <!-- 教育大綱 -->
    <section class="bg-card rounded-lg p-6 shadow-sm mb-10">
      <h2 class="font-bold text-lg text-primary mb-4">教育大綱と学園構想の関係</h2>
      <p class="text-sm leading-relaxed text-muted mb-3">
        現在の<a href="https://www.city.suzaka.nagano.jp/material/files/group/25/82056942.pdf" target="_blank" class="underline">第2次須坂市教育大綱</a>（2021〜2025年度）には「学園構想」という文言はありません。<Cite n={13} />
        記載されているのは「学校規模適正化等の教育環境の整備」という抽象的な一文のみです。
      </p>
      <p class="text-sm leading-relaxed text-muted">
        この教育大綱は<strong>2026年3月で期限切れ</strong>です。
        第3次教育大綱にどう位置づけるのか——これは市長が策定する文書です（地教行法第1条の3）。<Cite n={14} />
      </p>
    </section>

    <!-- 国はどう言っているか -->
    <section class="bg-card rounded-lg p-6 shadow-sm mb-10">
      <h2 class="font-bold text-lg text-primary mb-4">国（文科省）はどう言っているか</h2>
      <p class="text-xs text-muted mb-4">2026年3月11日公表 — 手引き改訂の議論まとめ（案）<Cite n={6} /></p>
      <div class="space-y-3">
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「統合と存続の一方を予め結論ありきで評価することを避けなければならない」
        </blockquote>
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「機械的に手引の考え方を適用することは適当ではない」
        </blockquote>
        <blockquote class="bg-gray-50 rounded-lg p-4 text-sm italic border-l-4 border-primary/30">
          「こどもの意見反映」は法的義務（こども基本法）
        </blockquote>
      </div>
    </section>

    <!-- 本当の問い -->
    <section class="bg-card rounded-lg p-6 shadow-sm mb-10 border-l-4 border-green-600">
      <h2 class="font-bold text-lg text-primary mb-4">必要なのは、比較検討です</h2>
      <p class="text-sm mb-4">問うべきは「統合するか/しないか」ではなく——</p>

      <div class="bg-green-50 rounded-lg p-5 mb-6">
        <p class="text-base font-bold text-center leading-relaxed">
          「15校をどう運営するのが、<br class="sm:hidden" />子どもにとって最も良く、財政的に持続可能か」
