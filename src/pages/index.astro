---
import Layout from '../layouts/Layout.astro'
import Cite from '../components/Cite.astro'
import RefList from '../components/RefList.astro'

const refs = [
  { n: 1, label: '須坂市教育委員会「新しい学校づくり」ページ', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '基本方針案・答申書・検討委員会議事録・説明会会議録を掲載' },
  { n: 2, label: '基本方針（案）Q&A（2025年4月）', url: 'https://www.city.suzaka.nagano.jp/material/files/group/25/kihonhoushinanQA.pdf', detail: '全28問中10問が「今後検討」（Q8,13,15,20,22,23,24,26,27,28）' },
  { n: 3, label: '答申書 資料10-1 p.21 問4-1「学校で取り組む課題の優先度」', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '13項目中「小中連携・小中一貫教育の推進」は構成比1.9%で最下位から2番目' },
  { n: 4, label: '答申書 資料10-5 p.86 問2-3「全校児童の数について」', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '今のままでよい=524人/721人(72.7%)' },
  { n: 5, label: '須坂市 2026年度予算案', url: 'https://www.city.suzaka.nagano.jp/', detail: '財政健全化実行宣言を発出済み' },
  { n: 6, label: '文科省 手引き改訂 議論のまとめ（案）概要（第9回 2026年3月11日）', url: 'https://www.mext.go.jp/content/20260310-mtx_syoto02-000047969-3.pdf' },
  { n: 7, label: '須坂市議会だより No.185', url: 'https://www.city.suzaka.nagano.jp/soshiki/10020/2/5944.html', detail: '2026年3月議会の学園構想関連質問を掲載' },
  { n: 8, label: '基本方針（案）（2024年12月）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '15校→4学園（義務教育学校）の構想' },
  { n: 9, label: '新しい学校づくりだより 1〜9号', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5875.html', detail: '教育委員会が市民向けに発行' },
  { n: 10, label: '地域説明会 会議録（2025年7〜8月 全8回）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '全12ブロック・8回開催の質疑応答を収録' },
  { n: 11, label: '検討委員会・策定委員会 議事録（2024〜2025年度）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '検討委員会3回＋策定委員会3回＋2025年度検討委員会1回' },
  { n: 12, label: '答申書（2023年12月13日）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '須坂市小中学校適正規模等審議会。資料10-1〜10-6にアンケート全数データ' },
]
---

<Layout title="須坂学園構想ウォッチ — 須坂の学校データ" description="須坂学園構想の進捗・未回答の質問・タイムラインを整理。市民が最新状況を追えるサイト">

  <!-- ヒーロー -->
  <section class="text-center mb-10">
    <p class="text-sm text-muted mb-2">最終更新: 2026年3月22日</p>
    <h1 class="text-3xl font-black text-primary mb-3">須坂学園構想ウォッチ</h1>
    <p class="text-muted max-w-xl mx-auto text-sm">
      教育委員会の動き・未回答の質問・タイムラインを整理しています。<br />
      データと出典をもとに、誰でも最新状況を追えるサイトです。
    </p>
  </section>

  <!-- 今ここ -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8 border-l-4 border-primary">
    <h2 class="font-bold text-lg text-primary mb-3">📍 今ここ</h2>
    <div class="flex flex-wrap gap-3 mb-4">
      <span class="bg-amber-100 text-amber-800 text-xs font-bold px-3 py-1 rounded-full">基本方針案 → パブコメ前</span>
      <span class="bg-red-100 text-red-800 text-xs font-bold px-3 py-1 rounded-full">費用: 未公表</span>
      <span class="bg-red-100 text-red-800 text-xs font-bold px-3 py-1 rounded-full">スケジュール: 未公表</span>
    </div>
    <p class="text-sm">
      須坂市は15校（小11＋中4）を<strong>4つの学園（義務教育学校）</strong>に再編する構想を進めています。<Cite n={1} />
      基本方針（案）は2024年12月に公表されましたが、費用・通学手段・通学区域などの具体策は「今後検討」のままです。<Cite n={2} />
    </p>
  </section>

  <!-- これから起きること -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-4">🔜 これから起きること</h2>
    <div class="space-y-3 text-sm">
      <div class="flex gap-3 items-start">
        <span class="bg-amber-100 text-amber-800 text-xs font-bold px-2 py-0.5 rounded shrink-0 mt-0.5">予定</span>
        <div>
          <span class="font-bold">2026年6月頃</span> — パブリックコメント（市民の意見提出期間）
          <p class="text-muted text-xs mt-0.5">基本方針案に対する市民の意見を公式に募集。提出された意見は公開される</p>
        </div>
      </div>
      <div class="flex gap-3 items-start">
        <span class="bg-gray-200 text-gray-700 text-xs font-bold px-2 py-0.5 rounded shrink-0 mt-0.5">未定</span>
        <div>
          <span class="font-bold">2026年?月</span> — 基本方針の正式決定
        </div>
      </div>
      <div class="flex gap-3 items-start">
        <span class="bg-gray-200 text-gray-700 text-xs font-bold px-2 py-0.5 rounded shrink-0 mt-0.5">未定</span>
        <div>
          <span class="font-bold">2027年〜?</span> — 第一学園（高甫小＋東中）の開校準備
        </div>
      </div>
    </div>
  </section>

  <!-- まだ決まっていないこと -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8 border-l-4 border-accent">
    <h2 class="font-bold text-lg text-primary mb-2">⚠️ まだ決まっていないこと</h2>
    <p class="text-xs text-muted mb-4">教育委員会のQ&A（全28問）のうち、<strong>10問が「今後検討」</strong>と回答されています。<Cite n={2} /></p>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="bg-red-50 rounded p-3">
        <div class="font-bold text-sm mb-1">💰 費用</div>
        <p class="text-xs text-muted">建設・改修にいくらかかるのか未公表。パターンにより市負担は6億〜88億円と10倍以上の幅がある</p>
      </div>
      <div class="bg-red-50 rounded p-3">
        <div class="font-bold text-sm mb-1">🚌 スクールバス</div>
        <p class="text-xs text-muted">運行区域・時間・停留所など「具体的な導入方法は今後検討」（Q20）</p>
      </div>
      <div class="bg-red-50 rounded p-3">
        <div class="font-bold text-sm mb-1">📍 通学区域</div>
        <p class="text-xs text-muted">どの町がどの学園に属するか「居住する町（自治会）により決定」（Q17）。具体的な線引きは未定</p>
      </div>
      <div class="bg-red-50 rounded p-3">
        <div class="font-bold text-sm mb-1">📚 カリキュラム</div>
        <p class="text-xs text-muted">小中一貫の具体的な教育課程は「カリキュラム開発委員会で検討」（Q15）</p>
      </div>
      <div class="bg-red-50 rounded p-3">
        <div class="font-bold text-sm mb-1">🏫 廃校の使い道</div>
        <p class="text-xs text-muted">使わなくなった校舎は「地域の皆様と相談しながら検討」（Q28）</p>
      </div>
      <div class="bg-red-50 rounded p-3">
        <div class="font-bold text-sm mb-1">👕 制服・校歌・PTA</div>
        <p class="text-xs text-muted">学校名・制服・校歌は「準備委員会で検討」（Q23）、PTAも「協議して決める」（Q22）</p>
      </div>
    </div>
  </section>

  <!-- 数字で見る現状 -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-4">📊 数字で見る現状</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
      <div>
        <div class="text-2xl font-black text-accent">1.9%</div>
        <div class="text-xs text-muted mt-1">市民が小中一貫を<br />優先した割合<Cite n={3} /></div>
      </div>
      <div>
        <div class="text-2xl font-black text-accent">73%</div>
        <div class="text-xs text-muted mt-1">児童が「今のまま<br />でよい」と回答<Cite n={4} /></div>
      </div>
      <div>
        <div class="text-2xl font-black text-accent">10/28</div>
        <div class="text-xs text-muted mt-1">Q&Aで「今後<br />検討」の回答数<Cite n={2} /></div>
      </div>
      <div>
        <div class="text-2xl font-black text-accent">約2億</div>
        <div class="text-xs text-muted mt-1">2026年度末の<br />財政調整基金<Cite n={5} /></div>
      </div>
    </div>
  </section>

  <!-- これまでの経緯 -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-4">📅 これまでの経緯</h2>
    <p class="text-xs text-muted mb-4">各項目のリンクから原文資料を直接確認できます。</p>
    <div class="space-y-0">
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary"></div>
        <div>
          <div class="text-xs text-muted">2026年3月</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/soshiki/10020/2/5944.html" target="_blank" class="underline hover:text-accent">3月議会で学園構想関連の質問</a><Cite n={7} /><span class="ml-2 text-xs text-accent font-normal">NEW</span></div>
          <div class="text-xs text-muted">教育長「反対の方がほとんどの話し合いには行けない」と答弁</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary"></div>
        <div>
          <div class="text-xs text-muted">2026年3月11日</div>
          <div class="text-sm font-bold"><a href="https://www.mext.go.jp/content/20260310-mtx_syoto02-000047969-3.pdf" target="_blank" class="underline hover:text-accent">文科省が手引き改訂の議論まとめ（案）を公表</a><Cite n={6} /></div>
          <div class="text-xs text-muted">「結論ありきで評価することを避けなければならない」「機械的に適用することは適当ではない」</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/50"></div>
        <div>
          <div class="text-xs text-muted">2025年11月6日</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html" target="_blank" class="underline hover:text-accent">検討委員会 第1回（2025年度）</a><Cite n={11} /></div>
          <div class="text-xs text-muted">議事録は市HPで公開</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/50"></div>
        <div>
          <div class="text-xs text-muted">2025年7〜8月</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html" target="_blank" class="underline hover:text-accent">地域説明会（全12ブロック・8回開催）</a><Cite n={10} /></div>
          <div class="text-xs text-muted"><a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html" target="_blank" class="underline">会議録PDF（全8回分）</a>を市HPで公開</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/50"></div>
        <div>
          <div class="text-xs text-muted">2025年4月</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/material/files/group/25/kihonhoushinanQA.pdf" target="_blank" class="underline hover:text-accent">基本方針（案）Q&A 公表</a><Cite n={2} /></div>
          <div class="text-xs text-muted">全28問。うち10問が「今後検討」</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/50"></div>
        <div>
          <div class="text-xs text-muted">2025年</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5875.html" target="_blank" class="underline hover:text-accent">新しい学校づくりだより（1〜9号）</a><Cite n={9} /></div>
          <div class="text-xs text-muted">教育委員会が市民向けに発行したニュースレター</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/50"></div>
        <div>
          <div class="text-xs text-muted">2024年12月</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html" target="_blank" class="underline hover:text-accent">基本方針（案）公表</a><Cite n={8} /></div>
          <div class="text-xs text-muted">15校→4学園（義務教育学校）の構想</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/30"></div>
        <div>
          <div class="text-xs text-muted">2024年度</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html" target="_blank" class="underline hover:text-accent">検討委員会 3回＋策定委員会 3回</a><Cite n={11} /></div>
          <div class="text-xs text-muted">議事録は市HPで公開</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/30"></div>
        <div>
          <div class="text-xs text-muted">2023年12月13日</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html" target="_blank" class="underline hover:text-accent">適正規模等審議会 答申書</a><Cite n={12} /></div>
          <div class="text-xs text-muted">資料10-1〜10-6に市民・保護者・教職員・児童・生徒アンケートの全数データを掲載</div>
        </div>
      </div>
      <div class="flex gap-4 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary/30"></div>
        <div>
          <div class="text-xs text-muted">2022年9〜11月</div>
          <div class="text-sm font-bold">市民・保護者・教職員・児童・生徒アンケート実施<Cite n={12} /></div>
          <div class="text-xs text-muted">配布5,958人、回収3,464人（回収率58.1%）。結果は<a href="https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html" target="_blank" class="underline">答申書</a>に収録</div>
        </div>
      </div>
    </div>
  </section>

  <!-- もっと知りたい方へ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-primary mb-4">📖 もっと知りたい方へ</h2>
    <div class="grid gap-3 sm:grid-cols-2">
      <a href="/evidence" class="block bg-card rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-sm font-bold text-primary mb-1">根拠データ・事実カード</div>
        <p class="text-xs text-muted">アンケート数字・全国事例・財政データの分析</p>
      </a>
      <a href="/detail/shisaku-hikaku" class="block bg-card rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-sm font-bold text-primary mb-1">長野県4市の施策比較</div>
        <p class="text-xs text-muted">松本・佐久・長野・須坂の教育改革アプローチの違い</p>
      </a>
      <a href="/facility" class="block bg-card rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-sm font-bold text-primary mb-1">施設と財政</div>
        <p class="text-xs text-muted">校舎の状態・教育費の比較・コストシミュレーション</p>
      </a>
      <a href="/detail" class="block bg-card rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-sm font-bold text-primary mb-1">詳細資料一覧</div>
        <p class="text-xs text-muted">義務教育学校の全数調査・文科省手引き・統廃合事例・成功事例</p>
      </a>
    </div>
  </section>

  <!-- 出典 -->
  <RefList refs={refs} />

</Layout>
