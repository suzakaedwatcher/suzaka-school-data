---
import Layout from '../layouts/Layout.astro'
import Cite from '../components/Cite.astro'
import RefList from '../components/RefList.astro'
import CountUp from '../components/CountUp.astro'
import LineChart from '../components/LineChart.astro'
import SchoolMap from '../components/SchoolMap.astro'

const refs = [
  { n: 1, label: '須坂市教育委員会「新しい学校づくり」ページ', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '基本方針案・答申書・検討委員会議事録・説明会会議録を掲載' },
  { n: 2, label: '基本方針（案）Q&A（2025年4月）', url: 'https://www.city.suzaka.nagano.jp/material/files/group/25/kihonhoushinanQA.pdf', detail: '全28問中10問が「今後検討」（Q8,13,15,20,22,23,24,26,27,28）' },
  { n: 3, label: '答申書 資料10-1 p.21 問4-1「学校で取り組む課題の優先度」', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '13項目中「小中連携・小中一貫教育の推進」は構成比1.9%で最下位から2番目' },
  { n: 4, label: '答申書 資料10-5 p.86 問2-3「全校児童の数について」', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '今のままでよい=524人/721人(72.7%)' },
  { n: 5, label: '須坂市 2026年度予算案', url: 'https://www.city.suzaka.nagano.jp/', detail: '財政健全化実行宣言を発出済み' },
  { n: 6, label: '文科省 手引き改訂 議論のまとめ（案）概要（第9回 2026年3月11日）', url: 'https://www.mext.go.jp/content/20260310-mtx_syoto02-000047969-3.pdf' },
  { n: 7, label: '須坂市議会だより No.185', url: 'https://www.city.suzaka.nagano.jp/shigikai/koho_kocho/99.html', detail: '2026年3月議会の学園構想関連質問を掲載' },
  { n: 8, label: '基本方針（案）（2024年12月）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '15校→4学園（義務教育学校）の構想' },
  { n: 9, label: '新しい学校づくりだより 1〜9号', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5875.html', detail: '教育委員会が市民向けに発行' },
  { n: 10, label: '地域説明会 会議録（2025年7〜8月 全8回）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '全12ブロック・8回開催の質疑応答を収録' },
  { n: 11, label: '検討委員会・策定委員会 議事録（2024〜2025年度）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '検討委員会3回＋策定委員会3回＋2025年度検討委員会1回' },
  { n: 12, label: '答申書（2023年12月13日）', url: 'https://www.city.suzaka.nagano.jp/soshiki/10010/5/5525.html', detail: '須坂市小中学校適正規模等審議会。資料10-1〜10-6にアンケート全数データ' },
]
---

<Layout title="須坂学園構想ウォッチ — 須坂の学校データ" description="須坂学園構想の進捗・未回答の質問・タイムラインを整理。市民が最新状況を追えるサイト">

  <!-- ヒーロー -->
  <section class="text-center mb-6">
    <p class="text-sm text-muted mb-2">最終更新: 2026年3月23日</p>
    <h1 class="text-3xl font-black text-primary mb-3">須坂学園構想ウォッチ</h1>
    <p class="text-muted max-w-xl mx-auto text-sm">
      教育委員会の動き・未回答の質問・タイムラインを整理しています。<br />
      データと出典をもとに、誰でも最新状況を追えるサイトです。
    </p>
  </section>

  <!-- うちの子はどうなるの？ -->
  <section class="bg-blue-50 border-2 border-blue-300 rounded-lg p-6 mb-8 text-center">
    <h2 class="font-black text-lg text-blue-900 mb-2">うちの子はどうなるの？</h2>
    <p class="text-sm text-blue-800 mb-4">学校を選ぶと、統合の時期・通学距離・教育への影響がわかります</p>
    <a href="/school" class="inline-block bg-blue-600 text-white font-bold text-sm px-6 py-3 rounded-full hover:bg-blue-700 transition-colors">学校を選んで確認する →</a>
  </section>

  <!-- クイックナビ -->
  <nav class="flex flex-wrap justify-center gap-2 mb-8 hero-nav">
    <a href="/core" class="bg-card border border-primary/20 text-primary text-xs font-bold px-4 py-2 rounded-full hover:bg-primary hover:text-white transition-colors">何が問題なのか</a>
    <a href="/facility" class="bg-card border border-primary/20 text-primary text-xs font-bold px-4 py-2 rounded-full hover:bg-primary hover:text-white transition-colors">施設と財政</a>
    <a href="/detail/cost-comparison" class="bg-card border border-primary/20 text-primary text-xs font-bold px-4 py-2 rounded-full hover:bg-primary hover:text-white transition-colors">5案の比較</a>
    <a href="/detail/nier-analysis" class="bg-card border border-primary/20 text-primary text-xs font-bold px-4 py-2 rounded-full hover:bg-primary hover:text-white transition-colors">須坂モデルの出自</a>
    <a href="/evidence/voices" class="bg-card border border-primary/20 text-primary text-xs font-bold px-4 py-2 rounded-full hover:bg-primary hover:text-white transition-colors">保護者と市民の声</a>
    <a href="/action" class="bg-green-50 border border-green-300 text-green-800 text-xs font-bold px-4 py-2 rounded-full hover:bg-green-600 hover:text-white transition-colors">市民にできること</a>
  </nav>

  <!-- 今ここ -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8 border-l-4 border-primary">
    <h2 class="font-bold text-lg text-primary mb-3"><span class="pin-drop">📍</span> 今ここ</h2>
    <div class="flex flex-wrap gap-3 mb-4">
      <span class="bg-amber-100 text-amber-800 text-xs font-bold px-3 py-1 rounded-full">基本方針案 → パブコメ前</span>
      <span class="bg-gray-100 text-gray-700 text-xs font-bold px-3 py-1 rounded-full">費用: 今後公表</span>
      <span class="bg-gray-100 text-gray-700 text-xs font-bold px-3 py-1 rounded-full">詳細スケジュール: 今後公表</span>
    </div>
    <p class="text-sm">
      須坂市は15校（小11＋中4）を<strong>4つの学園（義務教育学校）</strong>に再編する構想を進めています。<Cite n={1} />
    </p>
    <p class="text-sm mt-2">
      基本方針（案）は2024年12月に公表されました。費用・通学手段・通学区域などの具体策は今後検討・公表される予定です。<Cite n={2} />
    </p>
  </section>

  <!-- これから起きること -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-4">🔜 これから起きること</h2>
    <div class="space-y-3 text-sm">
      <div class="flex gap-3 items-start">
        <span class="bg-amber-100 text-amber-800 text-xs font-bold px-2 py-0.5 rounded shrink-0 mt-0.5">予定</span>
        <div>
          <span class="font-bold">2026年6月頃</span> — パブリックコメント（市民の意見提出期間）
          <p class="text-muted text-xs mt-0.5">基本方針案に対する市民の意見を公式に募集。提出された意見は公開される</p>
        </div>
      </div>
      <div class="flex gap-3 items-start">
        <span class="bg-gray-200 text-gray-700 text-xs font-bold px-2 py-0.5 rounded shrink-0 mt-0.5">未定</span>
        <div>
          <span class="font-bold">2026年?月</span> — 基本方針の正式決定
        </div>
      </div>
      <div class="flex gap-3 items-start">
        <span class="bg-gray-200 text-gray-700 text-xs font-bold px-2 py-0.5 rounded shrink-0 mt-0.5">未定</span>
        <div>
          <span class="font-bold">2027年〜?</span> — 第一学園（高甫小＋東中）の開校準備
        </div>
      </div>
    </div>
  </section>

  <!-- これから決まること -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8 border-l-4 border-primary">
    <h2 class="font-bold text-lg text-primary mb-2">これから決まること</h2>
    <p class="text-xs text-muted mb-4">教育委員会の<a href="https://www.city.suzaka.nagano.jp/material/files/group/25/kihonhoushinanQA.pdf" target="_blank" class="text-primary underline">Q&A（全28問）</a>のうち、<strong>10問が「今後検討」</strong>と回答されています。パブリックコメント（2026年6月頃）までに情報が更新される可能性があります。<Cite n={2} /></p>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="bg-gray-50 rounded p-3">
        <div class="font-bold text-sm mb-1">💰 費用</div>
        <p class="text-xs text-muted">総費用は今後公表予定。当サイトの試算では、30年総負担は公表ベースで73.5億円、残す校舎の改修費を含めると<strong>92〜119億円</strong>。<a href="/detail/cost-comparison" class="text-primary underline">詳細</a></p>
      </div>
      <div class="bg-gray-50 rounded p-3">
        <div class="font-bold text-sm mb-1">🚌 スクールバス</div>
        <p class="text-xs text-muted">運行区域・時間・停留所など「具体的な導入方法は今後検討」（Q20）</p>
      </div>
      <div class="bg-gray-50 rounded p-3">
        <div class="font-bold text-sm mb-1">📍 通学区域</div>
        <p class="text-xs text-muted">どの町がどの学園に属するか「居住する町（自治会）により決定」（Q17）。具体的な線引きは今後検討</p>
      </div>
      <div class="bg-gray-50 rounded p-3">
        <div class="font-bold text-sm mb-1">📚 カリキュラム</div>
        <p class="text-xs text-muted">小中一貫の具体的な教育課程は「カリキュラム開発委員会で検討」（Q15）</p>
      </div>
      <div class="bg-gray-50 rounded p-3">
        <div class="font-bold text-sm mb-1">🏫 閉校後の校舎</div>
        <p class="text-xs text-muted">「地域の皆様と相談しながら検討」（Q28）</p>
      </div>
      <div class="bg-gray-50 rounded p-3">
        <div class="font-bold text-sm mb-1">👕 制服・校歌・PTA</div>
        <p class="text-xs text-muted">学校名・制服・校歌は「準備委員会で検討」（Q23）、PTAも「協議して決める」（Q22）</p>
      </div>
    </div>

    <details class="mt-4">
      <summary class="cursor-pointer text-sm font-bold text-primary hover:underline">「今後検討」10問の一覧を見る</summary>
      <div class="mt-3 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b">
              <th class="text-left py-2">Q</th>
              <th class="text-left py-2">質問</th>
              <th class="text-left py-2">回答の要旨</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b">
              <td class="py-2 font-mono">Q8</td>
              <td class="py-2">義務教育学校と小中一貫型学校で教育内容に差が生まれないか</td>
              <td class="py-2 text-accent">「カリキュラム開発委員会等で<strong>検討する予定</strong>」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q13</td>
              <td class="py-2">支援学校との交流活動は継続できるか</td>
              <td class="py-2 text-accent">「新しい学園においても交流活動が継続できるよう<strong>検討</strong>」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q15</td>
              <td class="py-2">小中一貫教育のカリキュラムの具体的な内容は</td>
              <td class="py-2 text-accent">「カリキュラム開発委員会の中で<strong>検討</strong>していきます」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q20</td>
              <td class="py-2">通学時間が長くなる場合、スクールバスは導入されるか</td>
              <td class="py-2 text-accent">「具体的な導入方法を<strong>検討したい</strong>」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q22</td>
              <td class="py-2">PTA活動はどうなるか</td>
              <td class="py-2 text-accent">「開校までに<strong>協議して決める</strong>」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q23</td>
              <td class="py-2">学校名・校歌・制服はどうなるか</td>
              <td class="py-2 text-accent">「準備委員会で<strong>検討する予定</strong>」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q24</td>
              <td class="py-2">運動会や音楽会はどうなるか</td>
              <td class="py-2 text-accent">「準備委員会等で<strong>検討</strong>していきます」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q26</td>
              <td class="py-2">豊丘小と須坂小が統合した場合、児童クラブは</td>
              <td class="py-2 text-accent">「公共施設の活用を<strong>検討</strong>しています」</td>
            </tr>
            <tr class="border-b">
              <td class="py-2 font-mono">Q27</td>
              <td class="py-2">第二学園以降の児童クラブはどうなるか</td>
              <td class="py-2 text-accent">「児童クラブのあり方について<strong>検討</strong>していきます」</td>
            </tr>
            <tr>
              <td class="py-2 font-mono">Q28</td>
              <td class="py-2">学校として利用しなくなった校舎はどうなるか</td>
              <td class="py-2 text-accent">「<strong>まだ決まっていません</strong>。地域の皆様と相談しながら検討」</td>
            </tr>
          </tbody>
        </table>
        <p class="text-xs text-muted mt-2">出典: <a href="https://www.city.suzaka.nagano.jp/material/files/group/25/kihonhoushinanQA.pdf" target="_blank" class="text-primary underline">須坂学園構想 基本方針（案）Q&A</a>（2025年4月、全28問9ページ）</p>
      </div>
    </details>
  </section>

  <!-- 数字で見る現状 -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-4">📊 数字で見る現状</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <CountUp value={1.9} suffix="%" decimals={1} label="市民が小中一貫を優先した割合" source="市民アンケート 問4-1" />
      <CountUp value={73} suffix="%" label="児童が「今のままでよい」と回答" source="児童アンケート 問2-3" />
      <CountUp value={10} suffix="/28" label="Q&Aで「今後検討」の回答数" source="基本方針案Q&A" />
      <CountUp value={2} prefix="約" suffix="億" label="2026年度末の財政調整基金" source="2026年度予算案" />
    </div>
  </section>

  <!-- 児童生徒数の推移 -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-2">📉 児童生徒数の推移</h2>
    <p class="text-xs text-muted mb-4">出生数から推計した将来予測。少子化は事実であり、対策は必要です。問題は「どう対策するか」です。</p>
    <LineChart
      points={[
        { year: 1990, value: 7000, label: '35年前' },
        { year: 2016, value: 4800 },
        { year: 2024, value: 3628, label: '現在' },
        { year: 2030, value: 3132 },
        { year: 2035, value: 2700 },
        { year: 2040, value: 2300 },
        { year: 2050, value: 1800 },
        { year: 2065, value: 1200, label: '40年後' },
      ]}
      unit="人"
    />
    <p class="text-xs text-muted mt-2">出典: 須坂市教育委員会Q&A、国立社会保障・人口問題研究所「日本の地域別将来推計人口」</p>
  </section>

  <!-- 学校マップ -->
  <section id="school-map-section" class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-2">🗺 15校の位置と4学園の区割り</h2>
    <p class="text-xs text-muted mb-4">学校をホバー/タップすると詳細が表示されます。色は学園構想の区割りに対応しています。</p>
    <SchoolMap schools={[
      { name: '高甫小学校', lat: 36.6303, lng: 138.3118, type: 'elementary', gakuen: 1, students: 120, built: 1980 },
      { name: '仁礼小学校', lat: 36.6113, lng: 138.3417, type: 'elementary', gakuen: 1, students: 55, built: 1982 },
      { name: '豊丘小学校', lat: 36.6326, lng: 138.3515, type: 'elementary', gakuen: 2, students: 47, built: 1983 },
      { name: '須坂小学校', lat: 36.6533, lng: 138.3168, type: 'elementary', gakuen: 2, students: 350, built: 1973 },
      { name: '旭ケ丘小学校', lat: 36.6805, lng: 138.3157, type: 'elementary', gakuen: 2, students: 210, built: 1971 },
      { name: '森上小学校', lat: 36.6511, lng: 138.3042, type: 'elementary', gakuen: 3, students: 180, built: 1983 },
      { name: '日野小学校', lat: 36.6596, lng: 138.2922, type: 'elementary', gakuen: 3, students: 150, built: 1977 },
      { name: '豊洲小学校', lat: 36.6780, lng: 138.2935, type: 'elementary', gakuen: 3, students: 140, built: 1977 },
      { name: '井上小学校', lat: 36.6405, lng: 138.2861, type: 'elementary', gakuen: 4, students: 250, built: 1981 },
      { name: '小山小学校', lat: 36.6478, lng: 138.3120, type: 'elementary', gakuen: 4, students: 200, built: 1979 },
      { name: '日滝小学校', lat: 36.6622, lng: 138.3247, type: 'elementary', gakuen: 4, students: 160, built: 1979 },
      { name: '東中学校', lat: 36.6232, lng: 138.3319, type: 'middle', gakuen: 1, students: 143, built: 1995 },
      { name: '常盤中学校', lat: 36.6539, lng: 138.3200, type: 'middle', gakuen: 2, students: 351, built: 1987 },
      { name: '相森中学校', lat: 36.6625, lng: 138.3124, type: 'middle', gakuen: 3, students: 306, built: 1990 },
      { name: '墨坂中学校', lat: 36.6450, lng: 138.2974, type: 'middle', gakuen: 4, students: 490, built: 1993 },
    ]} />
  </section>

  <!-- これまでの経緯 -->
  <section class="bg-card rounded-lg p-6 shadow-sm mb-8">
    <h2 class="font-bold text-lg text-primary mb-4">📅 これまでの経緯</h2>
    <p class="text-xs text-muted mb-4">各項目のリンクから原文資料を直接確認できます。</p>
    <div class="space-y-0">
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary"></div>
        <div>
          <div class="text-xs text-muted">2026年3月</div>
          <div class="text-sm font-bold"><a href="https://www.city.suzaka.nagano.jp/shigikai/koho_kocho/99.html" target="_blank" class="underline hover:text-accent">3月議会で学園構想関連の質問</a><Cite n={7} /><span class="ml-2 text-xs text-accent font-normal">NEW</span></div>
          <div class="text-xs text-muted">教育長「反対の方がほとんどの話し合いには行けない」と答弁</div>
        </div>
      </div>
      <div class="flex gap-4 pb-4 border-l-2 border-primary/20 ml-2 pl-6 relative">
        <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-primary"></div>
        <div>
          <div class="text-xs text-muted">2026年3月11日</div>
          <div class="text-sm font-bold"><a href="https://www.mext.go.jp/content/20260310-mtx_syoto02-000047969-3.pdf" target="_blank" class="underline hover:text-accent">文科省が手引き改訂の議論まとめ（案）を公表</a><Cite n={6} /></div>
          <div class="text-xs text-muted">「結論ありきで評価することを避けなければならない」「機械的に適用することは適当ではない」</div>
        </div>
      </div>
