---
import Layout from './Layout.astro'

interface Props {
  title: string
  backTo: string
  backLabel: string
}

const { title, backTo, backLabel } = Astro.props
---

<Layout title={`${title} | 須坂の学校データ`}>
  <a href={backTo} class="text-sm text-muted hover:underline">&larr; {backLabel}</a>
  <article class="mt-6 prose prose-sm max-w-none
    [&_h1]:text-2xl [&_h1]:font-black [&_h1]:text-primary [&_h1]:mb-6
    [&_h2]:text-lg [&_h2]:font-bold [&_h2]:text-primary [&_h2]:mt-10 [&_h2]:mb-4
    [&_h3]:text-base [&_h3]:font-bold [&_h3]:mt-8 [&_h3]:mb-3
    [&_p]:mb-4 [&_p]:leading-relaxed
    [&_table]:text-sm [&_table]:w-full [&_table]:my-4
    [&_th]:text-left [&_th]:py-2.5 [&_th]:px-2 [&_th]:border-b
    [&_td]:py-2.5 [&_td]:px-2 [&_td]:border-b [&_td]:border-gray-100
    [&_a]:text-blue-600 [&_a]:underline
    [&_blockquote]:border-l-4 [&_blockquote]:border-accent [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:my-6
    [&_ul]:space-y-2 [&_ul]:my-4 [&_li]:text-sm [&_li]:leading-relaxed
    [&_ol]:space-y-2 [&_ol]:my-4
    [&_hr]:my-8
    [&_strong]:text-primary
  ">
    <slot />
  </article>
</Layout>
