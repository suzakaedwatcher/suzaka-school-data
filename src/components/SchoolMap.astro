---
interface School {
  name: string
  lat: number
  lng: number
  type: 'elementary' | 'middle'
  gakuen: 1 | 2 | 3 | 4
  students?: number
  built?: number
}

interface Props {
  schools: School[]
}

const { schools } = Astro.props
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="school-map-leaflet">
  <div class="flex flex-wrap gap-3 mb-3">
    <span class="flex items-center gap-1 text-xs"><span class="w-3 h-3 rounded-full inline-block" style="background:#e74c3c"></span>第一学園</span>
    <span class="flex items-center gap-1 text-xs"><span class="w-3 h-3 rounded-full inline-block" style="background:#2980b9"></span>第二学園</span>
    <span class="flex items-center gap-1 text-xs"><span class="w-3 h-3 rounded-full inline-block" style="background:#27ae60"></span>第三学園</span>
    <span class="flex items-center gap-1 text-xs"><span class="w-3 h-3 rounded-full inline-block" style="background:#f39c12"></span>第四学園</span>
    <span class="flex items-center gap-1 text-xs">●小学校　■中学校</span>
    <span class="flex items-center gap-1 text-xs text-muted">破線円=徒歩4km概算（迂回係数×1.3で補正）</span>
  </div>
  <div id="school-map" class="rounded-lg border" style="height: 560px; z-index: 0;"></div>
  <p class="text-xs text-muted mt-2">
    <strong>破線円</strong>は徒歩4km圏の概算です（道路は直線より約1.3倍長くなるため補正）。円の外はスクールバス対象になると思われますが、<strong>円の内側でも片道最大4km</strong>。小学1年生でもこの距離を歩いて通うことになります。
  </p>
</div>

<script type="module" define:vars={{ schools }}>
  const L = await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js');

  const map = L.map('school-map', { scrollWheelZoom: false }).setView([36.650, 138.310], 13);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18,
  }).addTo(map);

  const colors = { 1: '#e74c3c', 2: '#2980b9', 3: '#27ae60', 4: '#f39c12' };
  const gakuenNames = { 1: '第一学園', 2: '第二学園', 3: '第三学園', 4: '第四学園' };

  schools.forEach(s => {
    const color = colors[s.gakuen];
    if (s.type === 'middle') {
      const walkRadius = Math.round(4000 / 1.3);

      // 破線円: 徒歩4km概算（直線距離 ÷ 迂回係数1.3）
      L.circle([s.lat, s.lng], {
        radius: walkRadius,
        color: color,
        fillColor: color,
        fillOpacity: 0.06,
        weight: 2.5,
        opacity: 0.5,
        dashArray: '8 6',
      }).addTo(map);

      // 注釈: 円の上端に「徒歩4km」ラベル
      const labelPos = [s.lat + walkRadius / 111320, s.lng];
      L.marker(labelPos, {
        icon: L.divIcon({
          html: `<div class="circle-label" style="color:${color}">徒歩4km</div>`,
          className: '',
          iconSize: [0, 0],
          iconAnchor: [0, 10],
        }),
        interactive: false,
      }).addTo(map);
    }

    const size = s.type === 'middle' ? 12 : 9;
    const shape = s.type === 'middle'
      ? `<div style="width:${size * 2}px;height:${size * 2}px;background:${color};border:2px solid white;border-radius:3px;box-shadow:0 1px 4px rgba(0,0,0,0.3);"></div>`
      : `<div style="width:${size * 2}px;height:${size * 2}px;background:${color};border:2px solid white;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,0.3);"></div>`;

    const icon = L.divIcon({
      html: shape,
      className: '',
      iconSize: [size * 2, size * 2],
      iconAnchor: [size, size],
    });

    const age = 2026 - (s.built || 2000);
    const marker = L.marker([s.lat, s.lng], { icon }).addTo(map);
    marker.bindPopup(
      `<strong>${s.name}</strong><br>` +
      `<span style="color:${color};font-weight:bold;">${gakuenNames[s.gakuen]}</span><br>` +
      (s.students ? `児童生徒数: ${s.students}人<br>` : '') +
      (s.built ? `築${age}年（${s.built}年築）` : ''),
      { closeButton: false }
    );
    marker.bindTooltip(s.name.replace('小学校', '小').replace('中学校', '中'), {
      permanent: true,
      direction: 'bottom',
      offset: [0, 8],
      className: 'school-label',
    });
  });
</script>

<style>
  .school-label {
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    font-size: 10px !important;
    font-weight: bold !important;
    color: #374151 !important;
    text-shadow: 0 0 3px white, 0 0 3px white, 0 0 3px white !important;
    padding: 0 !important;
  }
  .circle-label {
    font-size: 11px;
    font-weight: bold;
    white-space: nowrap;
    text-shadow: 0 0 4px white, 0 0 4px white, 0 0 4px white, 0 0 4px white;
    pointer-events: none;
  }
</style>
