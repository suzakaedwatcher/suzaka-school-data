---
interface Props {
  value: string
  label: string
  source?: string
}

const { value, label, source } = Astro.props
---

<div class="text-center py-4">
  <div class="text-5xl font-black text-accent">{value}</div>
  <div class="text-sm text-muted mt-1">{label}</div>
  {source && <div class="text-xs text-gray-400 mt-1">出典: {source}</div>}
</div>
