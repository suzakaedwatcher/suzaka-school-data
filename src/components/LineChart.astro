---
interface Point {
  year: number
  value: number
  label?: string
}

interface Props {
  points: Point[]
  unit?: string
  height?: number
  color?: string
  areaColor?: string
}

const { points, unit = '', height = 200, color = '#e74c3c', areaColor = 'rgba(231,76,60,0.1)' } = Astro.props

const minY = 0
const maxY = Math.ceil(Math.max(...points.map(p => p.value)) / 1000) * 1000
const minX = Math.min(...points.map(p => p.year))
const maxX = Math.max(...points.map(p => p.year))
const padL = 45
const padR = 15
const padT = 20
const padB = 30
const w = 600
const h = height

function x(year: number) { return padL + (year - minX) / (maxX - minX) * (w - padL - padR) }
function y(val: number) { return padT + (1 - (val - minY) / (maxY - minY)) * (h - padT - padB) }

const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'}${x(p.year).toFixed(1)},${y(p.value).toFixed(1)}`).join(' ')
const areaPath = linePath + ` L${x(points[points.length - 1].year).toFixed(1)},${y(0).toFixed(1)} L${x(points[0].year).toFixed(1)},${y(0).toFixed(1)} Z`

const gridLines = [1000, 2000, 3000, 4000, 5000, 6000, 7000].filter(v => v <= maxY)
---

<div class="line-chart-wrapper overflow-x-auto">
  <svg viewBox={`0 0 ${w} ${h}`} class="w-full" style={`max-height: ${h}px`}>
    <!-- grid -->
    {gridLines.map(v => (
      <g>
        <line x1={padL} y1={y(v)} x2={w - padR} y2={y(v)} stroke="#e5e7eb" stroke-width="1" />
        <text x={padL - 5} y={y(v) + 4} text-anchor="end" fill="#9ca3af" font-size="10">{(v / 1000).toFixed(0)}k</text>
      </g>
    ))}
    <line x1={padL} y1={y(0)} x2={w - padR} y2={y(0)} stroke="#d1d5db" stroke-width="1" />

    <!-- area -->
    <path d={areaPath} fill={areaColor} class="line-chart-area" opacity="0" />

    <!-- line -->
    <path d={linePath} fill="none" stroke={color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="line-chart-line" stroke-dasharray="1000" stroke-dashoffset="1000" />

    <!-- dots & labels -->
    {points.map(p => (
      <g class="line-chart-dot" opacity="0">
        <circle cx={x(p.year)} cy={y(p.value)} r="4" fill={color} />
        <text x={x(p.year)} y={y(p.value) - 10} text-anchor="middle" fill="#1a1a2e" font-size="11" font-weight="bold">{p.value.toLocaleString()}{unit}</text>
        {p.label && <text x={x(p.year)} y={y(p.value) - 22} text-anchor="middle" fill="#9ca3af" font-size="9">{p.label}</text>}
        <text x={x(p.year)} y={h - 5} text-anchor="middle" fill="#6b7280" font-size="10">{p.year}</text>
      </g>
    ))}
  </svg>
</div>

<script>
  function initLineChart() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        if (el.dataset.animated) return;
        el.dataset.animated = '1';

        const line = el.querySelector('.line-chart-line') as SVGPathElement;
        const area = el.querySelector('.line-chart-area') as SVGPathElement;
        const dots = el.querySelectorAll('.line-chart-dot') as NodeListOf<SVGGElement>;

        if (line) {
          line.style.transition = 'stroke-dashoffset 1.5s ease-out';
          line.style.strokeDashoffset = '0';
        }
        if (area) {
          setTimeout(() => {
            area.style.transition = 'opacity 0.8s ease-out';
            area.style.opacity = '1';
          }, 800);
        }
        dots.forEach((dot, i) => {
          setTimeout(() => {
            dot.style.transition = 'opacity 0.3s ease-out';
            dot.style.opacity = '1';
          }, 300 + i * 200);
        });
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.line-chart-wrapper').forEach(el => observer.observe(el));
  }
  initLineChart();
</script>
